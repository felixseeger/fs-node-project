{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/server.js": {
      "includeFiles": "api/server.js,api/routes/**,api/services/**,api/middleware/**,api/queue/**"
    }
  }
}
