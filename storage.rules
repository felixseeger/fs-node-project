rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isUnderSizeLimit(mb) {
      return request.resource.size <= mb * 1024 * 1024;
    }

    // Avatar Images:
    // Anyone can read avatars
    // Only the authenticated owner can upload/update/delete their own avatar
    // Must be an image under 5MB
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() 
                   && isOwner(userId)
                   && isImage()
                   && isUnderSizeLimit(5);
    }

    // User Image Assets:
    // Only the owner can read/write their own assets
    // Must be an image under 20MB
    match /assets/{userId}/{fileName} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow write: if isAuthenticated() 
                   && isOwner(userId)
                   && isImage()
                   && isUnderSizeLimit(20);
    }
    
    

    // Workflows thumbnails and media:
    match /workflows/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Default deny for everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
