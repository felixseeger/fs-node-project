rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // A completely locked down default rule: reject everything that doesn't match below.
    match /{document=**} {
      allow read, write: if false;
    }

    // Workflows collection
    match /workflows/{workflowId} {
      // Any logged-in user can create a workflow
      allow create: if request.auth != null;
      
      // Allow reading public workflows or own workflows
      allow read: if resource.data.isPublic == true || (request.auth != null && request.auth.uid == resource.data.userId);
      
      // Only owner can update or delete
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    // Add other collections here...
  }
}
