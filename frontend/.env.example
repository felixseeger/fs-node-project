# Optional: embed shrimbly/node-banana in production builds (Node Banana lab menu).
# Local dev uses Vite proxy /node-banana-dev → http://localhost:3000 when unset.
# VITE_NODE_BANANA_URL=https://your-node-banana-host.example

# --- API Configuration ---
# Optional: Only set for local dev pointing to external API
# In production, defaults to '/api' (same domain routing)
# VITE_API_URL=http://localhost:3001
VITE_POSTHOG_KEY=phc_...
VITE_POSTHOG_HOST=https://app.posthog.com
