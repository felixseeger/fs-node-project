export const Icon: React.FC<IconProps> = ({ name, size = 24, crt = true, className, style, ...props }) => {
  const content = paths[name];
  
  if (!content) {
    console.warn(`Icon "${name}" not found in Icon component`);
    return null;
  }
  
  return (
    <svg
      width={size}
      height={size}
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      strokeWidth="2"
      strokeLinecap="round"
      strokeLinejoin="round"
      className={`be-icon be-icon-${name} ${className || ''}`}
      style={{
        display: 'inline-block',
        verticalAlign: 'middle',
        ...(crt ? { filter: 'drop-shadow(-2px 0px 1px var(--pink)) drop-shadow(2px 0px 1px var(--darker-cyan))' } : {}),
        ...style,
      }}
      {...props}
    >
      {content}
    </svg>
  );
};

export default Icon;
